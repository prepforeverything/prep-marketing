# PrepEdu Marketing Kit — environment template
# Copy to `.env` (git-ignored) and fill in. Never commit real keys.
# Only set the keys for the providers/connectors you actually use.

# ============================================================
# Asset / media generation  (used by /mkt-generate-asset,
# marketing-media-designer, and the marketing-asset-generation skill)
# ============================================================
# All hosted image/video generation requires billing — there is no free tier.

# Google Gemini — Nano Banana (image), Imagen 4 (image), Veo (video), vision evaluate.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — gpt-image (the model the Codex CLI image tool wraps).
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# higgsfield.ai — stylized image + video. Key from the dashboard's API section.
# Get a key: https://cloud.higgsfield.ai
HIGGSFIELD_API_KEY=
# Required: the model id to use, copied from your higgsfield dashboard.
HIGGSFIELD_MODEL=

# --- Optional model overrides (else sensible current defaults are used) ---
# Preview model ids drift; override here instead of editing code.
# IMAGE_GEN_MODEL=gemini-2.5-flash-image      # or gemini-3-pro-image-preview (4K in-image text)
# IMAGEN_MODEL=imagen-4.0-generate-001         # or -ultra- / -fast- variants
# OPENAI_IMAGE_MODEL=gpt-image-2               # gpt-image-1 deprecates 2026-10-23
# VIDEO_GEN_MODEL=veo-3.1-generate-preview     # or veo-3.0-generate-001 (stable)
# MULTIMODAL_MODEL=gemini-2.5-flash            # vision model for --task evaluate

# Optional provider (documented in the integrations registry; NOT wired into the engine):
# MINIMAX_API_KEY=

# ============================================================
# Analytics / ads / messaging connectors  (used by /mkt-connect)
# Read-only first; see .prepkit/packs/marketing/integrations/registry.json
# ============================================================
# GA4_PROPERTY_ID=
# META_ACCESS_TOKEN=
# TIKTOK_ACCESS_TOKEN=
# ZALO_OA_ID=
# ZALO_APP_ID=
# ZALO_SECRET_KEY=
# PANCAKE_API_KEY=
