  "defaultModelProfile": "quality",
  "personas": [
    {
      "id": "head-of-marketing",
      "label": "Head of Marketing",
      "description": "Cross-pillar planning and orchestration for the PrepEdu marketing team.",
      "modelProfile": "quality",
      "hookProfile": "standard",
      "outputStyle": "teaching",
      "defaultMode": "design",
      "packs": [
        "marketing",
        "customer-prepedu"
      ]
    },
    {
      "id": "growth-lead",
      "label": "Growth / Performance Lead",
      "description": "Paid acquisition, SEO/ASO, CRO, and analytics.",
      "modelProfile": "quality",
      "hookProfile": "standard",
      "outputStyle": "balanced",
      "defaultMode": "build",
      "packs": [
        "marketing",
        "customer-prepedu"
      ]
    },
    {
      "id": "content-lead",
      "label": "Content & Brand Lead",
      "description": "Content strategy, copywriting, and social for the PrepEdu brand.",
      "modelProfile": "quality",
      "hookProfile": "standard",
      "outputStyle": "balanced",
      "defaultMode": "build",
      "packs": [
        "marketing",
        "customer-prepedu"
      ]
    },
    {
      "id": "gtm-lead",
      "label": "Product / GTM Lead",
      "description": "Launches, competitive intel, pricing message, and sales enablement.",
      "modelProfile": "quality",
      "hookProfile": "standard",
      "outputStyle": "balanced",
      "defaultMode": "design",
      "packs": [
        "marketing",
        "customer-prepedu"
      ]
    },
    {
      "id": "ltv-lead",
      "label": "LTV / Retention Lead",
      "description": "Segmentation, lifecycle flows, reactivation, and cross-sell.",
      "modelProfile": "quality",
      "hookProfile": "standard",
      "outputStyle": "balanced",
      "defaultMode": "build",
      "packs": [
        "marketing",
        "customer-prepedu"
      ]
    },
    {
      "id": "ops-lead",
      "label": "Marketing Ops Lead",
      "description": "Reporting, dashboards, SOPs, and tracking governance.",
      "modelProfile": "balanced",
      "hookProfile": "standard",
      "outputStyle": "concise",
      "defaultMode": "build",
      "packs": [
        "marketing",
        "customer-prepedu"
      ]
