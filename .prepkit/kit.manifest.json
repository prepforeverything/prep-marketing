{
  "name": "prepedu-marketing",
  "displayName": "PrepEdu Marketing Kit",
  "version": "1.58.2",
  "description": "PrepEdu marketing agents kit — a guided, manifest-first Claude Code kit for non-technical marketers (campaigns, content, SEO/ASO, GTM, retention, ops), grounded in PrepEdu context with claims governance and sage-memory.",
  "settings": {
    "includeCoAuthoredBy": false
  },
  "claude": {
    "commandScope": "selected-packs"
  },
  "codex": {
    "skillScope": "routers"
  },
  "documentation": {
    "maxLoc": 600
  },
  "outputStyles": {
    "default": "balanced",
    "levels": [
      {
        "id": "concise",
        "label": "Concise",
        "description": "Minimal prose. Lead with code or commands. Skip explanations unless asked."
      },
      {
        "id": "balanced",
        "label": "Balanced",
        "description": "Direct and technical like a senior engineer, but explain the why behind decisions and trade-offs. Teach when the domain is unfamiliar; be terse when it is not."
      },
      {
        "id": "teaching",
        "label": "Teaching",
        "description": "Include full context and reasoning. Explain why, not just what. Define terms on first use. Good for onboarding or unfamiliar domains."
      }
    ]
  },
  "hookProfiles": {
    "default": "standard",
    "envVar": "PREP_HOOK_PROFILE",
    "tiers": [
      {
        "id": "minimal",
        "label": "Minimal",
        "description": "Core hooks only — session init, subagent init, pre-tool guard, dev-rules reminder. Fastest profile."
      },
      {
        "id": "standard",
        "label": "Standard",
        "description": "All current hooks plus quality gates (config protection, compact suggestions, cost tracking, batch format). Recommended for daily use."
      },
      {
        "id": "strict",
        "label": "Strict",
        "description": "Maximum safety, audit, and automation. Includes bash audit logging and auto-tmux dev server advisory."
      }
    ],
    "profileMapPath": ".claude/hooks/lib/hook-profile-map.cjs"
  },
  "paths": {
    "docs": "docs",
    "plans": "plans",
    "reports": "reports",
    "spec": "spec",
    "activePlans": "plans/active",
    "archivedPlans": "plans/archive",
    "planReports": "plans/reports",
    "planResearch": "plans/research",
    "planTemplates": "plans/templates",
    "activePlanTemplate": "plans/templates/active-plan",
    "docsFoundation": ".prepkit/docs/foundation",
    "docsGuides": ".prepkit/docs/guides",
    "docsReference": ".prepkit/docs/reference",
    "knowledgeBase": ".prepkit/docs/reference/knowledge",
    "knowledgeIndex": ".prepkit/docs/reference/knowledge/INDEX.md",
    "memoryIndexData": ".prepkit/memory-index.json",
    "resumeBrief": "reports/resume-brief.md",
    "docsDecisions": "docs/decisions",
    "docsArchive": "docs/archive",
    "flutterBuildCache": ".claude-build"
  },
  "plan": {
    "namingFormat": "{date}-{slug}",
    "dateFormat": "YYMMDD-HHmm",
    "branchPattern": "(?:feat|fix|chore|docs|refactor)/(?:[^/]+/)?(.+)"
  },
  "delivery": {
    "sessionMetrics": "minimal",
    "routing": {
      "defaultMode": "build",
      "uncertainEscalation": [
        "patch->build",
        "build->design"
      ]
    },
    "intents": [
      {
        "id": "review",
        "description": "Review current code, plans, or changes without entering delivery mode."
      },
      {
        "id": "explain",
        "description": "Explain existing code, behavior, or architecture without creating a delivery plan."
      },
      {
        "id": "research",
        "description": "Collect evidence or comparisons without committing to implementation work yet."
      }
    ],
    "modes": [
      {
        "id": "patch",
        "description": "Small bounded change with minimal planning overhead.",
        "planShape": "compact",
        "autonomy": "high",
        "validation": "targeted",
        "approvalCheckpoints": [
          "after-plan",
          "before-long-autonomous-execution"
        ],
        "spec": {
          "required": false,
          "requiredFiles": []
        },
        "complexityThresholds": {
          "maxFiles": 2
        }
      },
      {
        "id": "build",
        "description": "Standard scoped delivery flow for implementation-heavy work.",
        "planShape": "standard",
        "autonomy": "high",
        "validation": "changed-surface",
        "approvalCheckpoints": [
          "after-plan",
          "before-long-autonomous-execution"
        ],
        "spec": {
          "required": false,
          "requiredFiles": []
        },
        "complexityThresholds": {
          "maxSteps": 15,
          "maxPhases": 4
        },
        "hardCheckpointTriggers": [
          "spec-creation",
          "contract-change",
          "cross-cutting-change",
          "long-autonomous-execution"
        ]
      },
      {
        "id": "design",
        "description": "Design-first work for ambiguous, cross-cutting, or larger initiatives.",
        "planShape": "spec-first",
        "autonomy": "high-until-implementation",
        "validation": "consistency-then-build",
        "approvalCheckpoints": [
          "after-design-and-plan",
          "before-long-autonomous-execution"
        ],
        "spec": {
          "required": true,
          "requiredFiles": [
            "spec/proposal.md",
            "spec/design.md",
            "spec/tasks.md"
          ]
        }
      }
    ]
  },
  "planPresets": [],
  "context": {
    "budgetMode": "advisory",
    "mainBudgetTokens": 1600,
    "subagentBudgetTokens": 400,
    "warningPercent": 70,
    "criticalPercent": 85,
    "contextWarningPercent": 65,
    "contextCriticalPercent": 75,
    "artifactBudgetChars": 800,
    "contextWindowTokens": 1000000,
    "sessionInitVerbosity": "lean",
    "lifecycleNudges": false
  },
  "modelProfiles": {
    "quality": {
      "planner": "opus",
      "researcher": "opus",
      "marketing-reviewer": "sonnet",
