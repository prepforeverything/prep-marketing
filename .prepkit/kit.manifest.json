  "modelRouting": {
    "modeOverrides": {
      "design": {
        "planner": "opus",
        "researcher": "opus"
      }
    },
    "laneOverrides": {}
  },
  "runtimePolicy": {
    "primaryHost": "claude-code",
    "branchFreshness": {
      "enabled": true,
      "checkpoint": "before-long-autonomous-execution",
      "defaultBranch": "main",
      "remoteName": "origin",
      "policy": "warn",
      "maxMissingSubjects": 5
    },
    "events": {
      "enabled": true,
      "path": ".prepkit/runtime-events.jsonl",
      "maxBytes": 1048576
    },
    "hosts": {
      "claude-code": {
        "label": "Claude Code-first",
        "nativeCapabilitySummary": "Claude Code already provides workspace file and shell operations.",
        "suppressReminderToolAdapters": [
          "workspace-files",
          "shell-execution"
        ],
        "statusLine": {
          "enabled": true,
          "command": "node .claude/hooks/statusline.cjs",
          "padding": 0
        },
        "reminderPolicy": [
          "Keep the always-loaded runtime focused on routing, memory, validation, and active-plan state.",
          "Do not restate host-native file-edit or shell-execution guidance as duplicate PrepKit reminder content."
        ]
      }
    }
  },
  "optionalAdapters": {
    "semanticCode": {
      "category": "tool-adapter",
      "status": "optional",
      "activation": "explicit opt-in",
      "transport": "mcp-or-host-specific adapter",
      "availabilitySignals": {
        "envVars": [
          "PREP_SEMANTIC_ADAPTER"
        ],
        "configPaths": [
          ".prepkit/optional-adapters/semantic-code.json"
        ]
      },
      "fallbackToolAdapters": [
        "workspace-files",
        "shell-execution"
      ],
      "fallbackBehavior": "Use file-centric search, reads, and patch flows when no semantic backend is available.",
      "canonicalWritePath": "Workspace files remain the only write path for source changes."
    },
    "retrievalSidecar": {
      "category": "tool-adapter",
      "status": "optional",
      "activation": "explicit opt-in",
      "transport": "mcp-stdio",
      "mcpServer": "prepkit-memory",
      "mcpTools": [
        "prepkit_memory_search",
        "prepkit_memory_graph",
        "prepkit_memory_browse",
        "prepkit_memory_store",
        "prepkit_memory_update",
        "prepkit_memory_delete",
        "prepkit_memory_link",
        "prepkit_memory_unlink",
        "prepkit_memory_learn",
        "prepkit_memory_promote",
        "prepkit_memory_review",
        "prepkit_memory_review_result",
        "prepkit_memory_consolidate",
        "prepkit_memory_fact_store",
        "prepkit_memory_fact_query",
        "prepkit_memory_reflect",
        "prepkit_memory_reindex_embeddings",
        "prepkit_memory_extract",
        "prepkit_memory_entity_search",
        "prepkit_memory_entity_merge",
        "prepkit_memory_feedback",
        "prepkit_memory_session_start",
        "prepkit_memory_session_end",
        "prepkit_memory_episode",
        "prepkit_memory_communities",
        "prepkit_memory_context",
        "prepkit_memory_focus",
        "prepkit_memory_bootstrap",
        "prepkit_memory_checkpoint",
        "prepkit_memory_conversation_import",
        "prepkit_memory_onboard",
        "prepkit_memory_entity_graph",
        "prepkit_memory_skill_contracts"
      ],
      "availabilitySignals": {
        "envVars": [
          "PREP_RETRIEVAL_SIDECAR"
        ],
        "configPaths": [
          ".prepkit/optional-adapters/retrieval-sidecar.json"
        ]
      },
      "fallbackToolAdapters": [
        "workspace-files",
        "shell-execution"
      ],
      "fallbackBehavior": "Use node .prepkit/scripts/memory-query.mjs plus direct file reads over canonical plans and docs when no sidecar is available.",
      "canonicalWritePath": "Plans, reports, specs, docs, and memory-curate stay canonical. MCP write tools (store, update, delete, link, learn) are supplementary — agents call them after canonical file writes, not instead of. The semantic DB is disposable and re-buildable from files."
    },
    "commandCompactor": {
      "category": "tool-adapter",
      "status": "optional",
      "activation": "explicit opt-in",
      "transport": "claude-pretool-rewrite + local provider subprocess",
      "availabilitySignals": {
        "envVars": [
          "PREP_COMMAND_COMPACTOR"
        ],
        "configPaths": [
          ".prepkit/optional-adapters/command-compactor.json"
        ]
      },
      "fallbackToolAdapters": [
        "shell-execution"
      ],
      "fallbackBehavior": "Run Bash commands unchanged when no compactor provider is configured or the provider declines a rewrite.",
      "canonicalWritePath": "Command compaction only rewrites Bash execution. Source-of-truth writes remain in workspace files, plans, docs, and other canonical PrepKit artifacts."
    },
    "gitbutlerClaude": {
      "category": "tool-adapter",
      "status": "optional",
      "activation": "explicit opt-in, recommended for Claude Code-first sessions",
      "transport": "claude-hook-forwarder + local but CLI",
      "availabilitySignals": {
        "envVars": [
          "PREP_GITBUTLER_CLAUDE"
        ],
        "configPaths": [
          ".prepkit/optional-adapters/gitbutler-claude.json"
        ]
      },
      "fallbackToolAdapters": [
        "shell-execution"
      ],
      "fallbackBehavior": "Continue the current PrepKit runtime without GitButler-managed branch orchestration. PrepKit's pre-tool guard remains the first and final blocking authority.",
      "canonicalWritePath": "Source changes still land in workspace files; plans, specs, reports, and docs remain canonical state. GitButler only orchestrates branch and commit isolation for Claude Code sessions that have opted in locally."
    }
  },
  "trajectory": {
    "enabled": false,
    "retentionSessions": 100,
    "maxRecordsPerSession": 5000,
    "hmacSaltEnvVar": "PREPKIT_TRAJECTORY_HMAC_SALT"
  },
  "memory": {
    "nudge": {
      "onSessionStart": false,
      "minIntervalHours": 24,
      "staleAfterDays": 30
    }
  },
  "proposeLessons": {
    "fileIndexSimilarityProbe": {
      "enabled": false,
      "timeoutMs": 1500,
      "minScore": 12
    }
  },
  "validation": {
    "routerFanoutWarnThreshold": 12,
    "planHeadings": {
