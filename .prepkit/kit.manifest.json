  "guardrails": {
    "blockedPaths": [
      "node_modules",
      ".git",
      "dist",
      "build",
      ".next",
      ".turbo",
      "coverage"
    ],
    "sensitivePatterns": [
      ".env.production*",
      ".env.prod*",
      ".env.staging*",
      ".env.live*",
      "*.pem",
      "*.key",
      "*credentials*",
      "*secret*.yaml",
      "*secret*.yml"
    ],
    "sensitivePatternEntries": [
      {
        "pattern": ".env.production*",
        "category": "env-production"
      },
      {
        "pattern": ".env.prod*",
        "category": "env-production"
      },
      {
        "pattern": ".env.staging*",
        "category": "env-production"
      },
      {
        "pattern": ".env.live*",
        "category": "env-production"
      },
      {
        "pattern": "*.pem",
        "category": "private-key"
      },
      {
        "pattern": "*.key",
        "category": "private-key"
      },
      {
        "pattern": "*credentials*",
        "category": "credentials"
      },
      {
        "pattern": "*secret*.yaml",
        "category": "secret-config"
      },
      {
        "pattern": "*secret*.yml",
        "category": "secret-config"
      }
    ],
    "longRunningPatterns": [
      "npm install",
      "npm run build",
      "npm test",
      "docker build",
      "pip install",
      "cargo build",
      "make\\b",
      "mvn ",
      "gradle "
    ],
    "secretDetection": {
      "mode": "advisory"
    }
  },
