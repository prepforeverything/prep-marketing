        "Plan Metadata",
        "Goal",
        "Current Context",
        "Scope",
        "Steps",
        "Memory Routing",
        "Constraints",
        "Workstreams",
        "Files In Scope",
        "Done Criteria",
        "Risks",
        "Open Questions"
