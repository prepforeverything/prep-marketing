        "## Scope",
        "## System Shape",
        "## Data And Contracts",
        "## Validation Plan",
        "## Risks"
      ],
      "spec/tasks.md": [
        "# Tasks"
      ]
    },
    "specTaskChecklist": {
      "files": [
        "spec/tasks.md"
      ],
      "requireAtLeastOneItem": true,
      "disallowNumberedItems": true
    }
  },
