{
  "name": "Dashboard doanh thu Thái — bấm giờ gọi GitHub",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "12 8 * * *" }
          ]
        }
      },
      "id": "schedule-0812",
      "name": "Lịch 08:12 (VN)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [380, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/prepforeverything/prep-marketing/actions/workflows/revdash-th-daily.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Accept", "value": "application/vnd.github+json" },
            { "name": "X-GitHub-Api-Version", "value": "2022-11-28" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"ref\": \"main\",\n  \"inputs\": { \"dry_run\": \"false\" }\n}",
        "options": {}
      },
      "id": "github-dispatch",
      "name": "Gọi GitHub chạy dashboard doanh thu Thái",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [640, 300],
      "credentials": {
        "httpHeaderAuth": { "id": "REPLACE_ME", "name": "GitHub dispatch token" }
      }
    }
  ],
  "connections": {
    "Lịch 08:12 (VN)": {
      "main": [
        [ { "node": "Gọi GitHub chạy dashboard doanh thu Thái", "type": "main", "index": 0 } ]
      ]
    }
  },
  "settings": {
    "timezone": "Asia/Ho_Chi_Minh"
  },
  "active": false
}
